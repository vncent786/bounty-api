{
  "name": "bountyapi-mcp",
  "version": "1.7.0",
  "mcpName": "io.github.vncent786/bounty-api",
  "description": "MCP server for BountyAPI — specialist data APIs for AI agents with x402 micropayments",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "bountyapi-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const f='dist/index.js';let c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!')){c='#!/usr/bin/env node\\n'+c;fs.writeFileSync(f,c)}\"",
    "start": "node dist/index.js",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "data-api",
    "api",
    "ai-agent",
    "x402",
    "property",
    "stamp-duty",
    "hdb",
    "singapore"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@x402/core": "^2.17.0",
    "@x402/evm": "^2.17.0",
    "@x402/fetch": "^2.17.0",
    "viem": "^2.48.11"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
